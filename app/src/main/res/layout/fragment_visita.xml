<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_blue_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 Registrar Ficha de Visita"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Cliente -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Cliente"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent_blue">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBuscarClienteVisita"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Digite o nome do cliente..."
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvClienteSelecionadoVisita"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum cliente selecionado"
                    android:textColor="@color/warning_orange"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:padding="8dp"
                    android:background="@color/surface_light"
                    android:gravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Data da Visita -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. Data da Visita"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent_blue">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDataVisita"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Selecione a data"
                        android:textColor="@color/white"
                        android:inputType="date"
                        android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Parâmetros da Água -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3. Parâmetros da Água"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent_blue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPh"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="pH"
                            android:textColor="@color/white"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent_blue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAlcalinidade"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Alcalinidade"
                            android:textColor="@color/white"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent_blue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCloro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Cloro"
                            android:textColor="@color/white"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Serviços Realizados -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4. Serviços Realizados"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <CheckBox
                        android:id="@+id/chkAspiracao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aspiração"
                        android:textColor="@color/white"
                        android:buttonTint="@color/accent_blue" />

                    <CheckBox
                        android:id="@+id/chkEscovacao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Escovação"
                        android:textColor="@color/white"
                        android:buttonTint="@color/accent_blue" />

                    <CheckBox
                        android:id="@+id/chkLimpezaBordas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Limpeza de Bordas"
                        android:textColor="@color/white"
                        android:buttonTint="@color/accent_blue" />

                    <CheckBox
                        android:id="@+id/chkPeneiracao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Peneiração"
                        android:textColor="@color/white"
                        android:buttonTint="@color/accent_blue" />

                    <CheckBox
                        android:id="@+id/chkLimpezaFiltro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Limpeza Filtro"
                        android:textColor="@color/white"
                        android:buttonTint="@color/accent_blue" />

                    <CheckBox
                        android:id="@+id/chkRetrolavagem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Retrolavagem"
                        android:textColor="@color/white"
                        android:buttonTint="@color/accent_blue" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Produtos Utilizados -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5. Produtos Utilizados (Opcional)"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent_blue">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etProdutos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ex: Cloro Granulado 500g, Clarificante 500ml..."
                        android:textColor="@color/white"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Observações -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="6. Observações"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent_blue">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etObservacoes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Comentários finais ou problemas na piscina..."
                        android:textColor="@color/white"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FOTOS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_medium"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="7. Fotos (Antes e Depois)"
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tire fotos da piscina antes e depois da limpeza"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <!-- Foto ANTES -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📸 Foto ANTES da limpeza:"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnFotoAntes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tirar Foto ANTES"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/warning_orange"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvFotoAntes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma foto selecionada"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@color/surface_light"
                    android:layout_marginBottom="16dp" />

                <!-- Foto DEPOIS -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📸 Foto DEPOIS da limpeza:"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnFotoDepois"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tirar Foto DEPOIS"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/success_green"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvFotoDepois"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma foto selecionada"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@color/surface_light" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botão Salvar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarVisita"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar Visita"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/success_green"
            app:cornerRadius="12dp"
            android:layout_marginTop="8dp" />

        <ProgressBar
            android:id="@+id/progressVisita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
